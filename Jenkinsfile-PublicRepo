                # Common constant/variable naming patterns (not internal keywords)
                'CHECK', 'VALIDATE', 'VERIFY', 'CONFIRM', 'ENSURE',
                'SKIP', 'IGNORE', 'EXCLUDE', 'INCLUDE', 'FILTER',
                'ALLOW', 'BLOCK', 'REJECT', 'ACCEPT', 'APPROVE',
                'SEND', 'RECEIVE', 'FETCH', 'RETRIEVE', 'QUERY',
