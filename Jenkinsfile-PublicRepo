// Jenkinsfile for Public Repository - Bob Validation Pipeline
// Special configuration for IBM contributors to external/public repositories

pipeline {
    agent any
    
    environment {
        // GitHub credentials for public repo
        GITHUB_TOKEN = credentials('github-token')
        
        // IBM Fork repository (where validation happens)
        IBM_FORK_REPO = "${params.IBM_FORK_REPO ?: 'karthikeyan-balakrishnan-ibm/c2c'}"
        
        // External/Public repository (final destination)
        PUBLIC_REPO = "${params.PUBLIC_REPO ?: 'IBM/c2c'}"
        
        // Bob Shell configuration
        BOB_SHELL_PATH = '/opt/homebrew/bin/bob'
        
        // Node.js configuration (required by Bob Shell)
        // Bob Shell requires Node.js to run. Update these paths based on your installation.
        // Common Node.js locations:
        //   - Homebrew (macOS): /opt/homebrew/bin
        //   - Standard (Linux): /usr/bin or /usr/local/bin
        //   - NVM: ~/.nvm/versions/node/vX.X.X/bin
        NODE_HOME = '/opt/homebrew/bin/node'  // Directory containing node executable
        PATH = "${NODE_HOME}:/usr/local/bin:/usr/bin:${env.PATH}"
        
        // Working directories
        WORKSPACE_DIR = "${WORKSPACE}"
        VALIDATION_DIR = "${WORKSPACE}/bob-validation"
        
        // Git configuration
        GIT_BRANCH = "${env.CHANGE_BRANCH ?: env.GIT_BRANCH}"
        BASE_BRANCH = "${env.CHANGE_TARGET ?: 'main'}"
        
        // IBM specific settings
        IBM_CONTRIBUTOR_EMAIL = "${env.CHANGE_AUTHOR_EMAIL ?: 'karthikeyan.balakrishnan1@ibm.com'}"
    }
    
    parameters {
        string(
            name: 'IBM_FORK_REPO',
            defaultValue: 'karthikeyan-balakrishnan-ibm/c2c',
            description: 'IBM fork repository (format: org/repo)'
        )
        string(
            name: 'PUBLIC_REPO',
            defaultValue: 'IBM/c2c',
            description: 'Public/external repository (format: org/repo)'
        )
        booleanParam(
            name: 'SKIP_VALIDATION',
            defaultValue: false,
            description: 'Skip Bob validation (emergency only - requires approval)'
        )
        booleanParam(
            name: 'AUTO_CREATE_PR',
            defaultValue: true,
            description: 'Automatically create PR to public repo after validation passes'
        )
        booleanParam(
            name: 'DEBUG_MODE',
            defaultValue: false,
            description: 'Enable debug output'
        )
    }
    
    options {
        buildDiscarder(logRotator(daysToKeepStr: '30', numToKeepStr: '50'))
        timeout(time: 20, unit: 'MINUTES')
        disableConcurrentBuilds()
        timestamps()
    }
    
    stages {
        stage('Initialize') {
            steps {
                script {
                    echo "🚀 Starting Bob Validation Pipeline for Public Repository"
                    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
                    echo "📋 Build Information:"
                    echo "   Job: ${env.JOB_NAME}"
                    echo "   Build: #${env.BUILD_NUMBER}"
                    echo "   IBM Fork: ${IBM_FORK_REPO}"
                    echo "   Public Repo: ${PUBLIC_REPO}"
                    echo "   Branch: ${GIT_BRANCH}"
                    echo "   Base Branch: ${BASE_BRANCH}"
                    echo "   PR: ${env.CHANGE_ID ?: 'N/A'}"
                    echo "   IBM Contributor: ${env.CHANGE_AUTHOR ?: 'N/A'}"
                    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
                    
                    // Verify this is an IBM contributor
                    if (IBM_CONTRIBUTOR_EMAIL && !IBM_CONTRIBUTOR_EMAIL.contains('@ibm.com')) {
                        echo "⚠️  Warning: Contributor email is not @ibm.com"
                        echo "   This pipeline is designed for IBM contributors only"
                    }
                    
                    // Create validation directory
                    sh """
                        mkdir -p ${VALIDATION_DIR}
                        echo "✅ Validation directory created: ${VALIDATION_DIR}"
                    """
                }
            }
        }
        
        stage('Verify Bob Shell') {
            steps {
                script {
                    echo "🔍 Verifying Bob Shell and Node.js availability..."
                    echo "   Bob Shell Path: ${BOB_SHELL_PATH}"
                    echo "   Node.js Path: ${NODE_HOME}"
                    
                    def verificationCheck = sh(
                        script: """
                            set +e  # Don't exit on error
                            ERRORS=0
                            
                            # Check Node.js
                            echo ""
                            echo "=== Checking Node.js ==="
                            if command -v node >/dev/null 2>&1; then
                                NODE_VERSION=\$(node --version)
                                echo "✅ Node.js found: \$NODE_VERSION"
                                echo "   Location: \$(which node)"
                            else
                                echo "❌ Node.js not found in PATH"
                                echo ""
                                echo "Searching for Node.js in common locations..."
                                ls -la /usr/bin/node 2>/dev/null || echo "  - Not in /usr/bin"
                                ls -la /usr/local/bin/node 2>/dev/null || echo "  - Not in /usr/local/bin"
                                ls -la /opt/homebrew/bin/node 2>/dev/null || echo "  - Not in /opt/homebrew/bin"
                                ls -la ~/.nvm/versions/node/*/bin/node 2>/dev/null || echo "  - Not in ~/.nvm"
                                echo ""
                                echo "⚠️  Bob Shell requires Node.js to run!"
                                echo "Please install Node.js or update NODE_HOME in Jenkinsfile"
                                ERRORS=\$((ERRORS + 1))
                            fi
                            
                            # Check Bob Shell
                            echo ""
                            echo "=== Checking Bob Shell ==="
                            if [ -f "${BOB_SHELL_PATH}" ]; then
                                echo "✅ Bob Shell found at: ${BOB_SHELL_PATH}"
                                
                                # Try to run Bob
                                if ${BOB_SHELL_PATH} --help >/dev/null 2>&1; then
                                    echo "✅ Bob Shell is executable and working"
                                    ${BOB_SHELL_PATH} --help | head -5
                                else
                                    echo "⚠️  Bob Shell exists but failed to run"
                                    echo "This might be due to missing Node.js or permissions"
                                    ERRORS=\$((ERRORS + 1))
                                fi
                            else
                                echo "❌ Bob Shell not found at: ${BOB_SHELL_PATH}"
                                echo ""
                                echo "Searching for Bob in common locations..."
                                which bob || echo "  - Not in PATH"
                                ls -la /usr/local/bin/bob 2>/dev/null || echo "  - Not in /usr/local/bin"
                                ls -la /opt/homebrew/bin/bob 2>/dev/null || echo "  - Not in /opt/homebrew/bin"
                                ls -la /opt/ibm/bob/bin/bob 2>/dev/null || echo "  - Not in /opt/ibm"
                                ls -la ~/.local/bin/bob 2>/dev/null || echo "  - Not in ~/.local/bin"
                                echo ""
                                echo "Please update BOB_SHELL_PATH in Jenkinsfile environment section"
                                ERRORS=\$((ERRORS + 1))
                            fi
                            
                            echo ""
                            echo "=== Verification Summary ==="
                            if [ \$ERRORS -eq 0 ]; then
                                echo "✅ All checks passed!"
                                exit 0
                            else
                                echo "❌ \$ERRORS error(s) found"
                                echo ""
                                echo "Common fixes:"
                                echo "1. Install Node.js: https://nodejs.org/"
                                echo "2. Update NODE_HOME in Jenkinsfile to point to Node.js bin directory"
                                echo "3. Update BOB_SHELL_PATH to correct Bob location"
                                echo "4. Ensure PATH includes both Node.js and Bob directories"
                                exit 1
                            fi
                        """,
                        returnStatus: true
                    )
                    
                    if (verificationCheck != 0) {
                        error("❌ Verification failed. Please check Node.js and Bob Shell installation.")
                    }
                    
                    echo "✅ Node.js and Bob Shell verified successfully"
                }
            }
        }
        
        stage('Checkout IBM Fork') {
            steps {
                script {
                    echo "📥 Checking out IBM fork repository..."
                    
                    // Checkout from IBM fork (not public repo)
                    checkout([
                        $class: 'GitSCM',
                        branches: [[name: "*/${GIT_BRANCH}"]],
                        userRemoteConfigs: [[
                            url: "https://github.com/${IBM_FORK_REPO}.git",
                            credentialsId: 'github-token'
                        ]]
                    ])
                    
                    // Add public repo as remote for reference
                    sh """
                        git remote add public https://github.com/${PUBLIC_REPO}.git || true
                        git fetch --all --prune
                        git branch -a
                        echo "✅ IBM fork checked out successfully"
                    """
                }
            }
        }
        
        stage('Verify IBM Fork Sync') {
            steps {
                script {
                    echo "🔄 Verifying IBM fork is synced with public repo..."
                    
                    sh """
                        # Fetch latest from public repo
                        git fetch public ${BASE_BRANCH}
                        
                        # Check if fork is behind
                        BEHIND=\$(git rev-list --count HEAD..public/${BASE_BRANCH})
                        
                        if [ "\$BEHIND" -gt 0 ]; then
                            echo "⚠️  IBM fork is \$BEHIND commits behind public repo"
                            echo "   Consider syncing the fork before proceeding"
                        else
                            echo "✅ IBM fork is up to date with public repo"
                        fi
                    """
                }
            }
        }
        
        stage('Collect PR Content') {
            steps {
                script {
                    echo "📦 Collecting PR content for validation..."
                    
                    // Create enhanced collection script for public repos
                    writeFile file: "${VALIDATION_DIR}/collect_pr_content.py", text: '''#!/usr/bin/env python3
import json
import subprocess
import sys
import os

def run_git_command(cmd):
    """Run git command and return output"""
    try:
        result = subprocess.run(
            cmd,
            capture_output=True,
            text=True,
            check=True,
            shell=True
        )
        return result.stdout.strip()
    except subprocess.CalledProcessError as e:
        print(f"Error running command: {cmd}")
        print(f"Error: {e.stderr}")
        return ""

def collect_pr_content(base_branch):
    """Collect all PR content for public repo submission"""
    print(f"Collecting PR content (base: {base_branch})...")
    
    # Get PR title from commit or environment
    pr_title = os.getenv('CHANGE_TITLE', run_git_command("git log -1 --pretty=format:'%s'"))
    
    # Get PR body/description
    pr_body = os.getenv('CHANGE_DESCRIPTION', run_git_command("git log -1 --pretty=format:'%b'"))
    
    # Get code changes (diff against public repo)
    print("Getting code diff against public repo...")
    code_changes = run_git_command(f"git diff public/{base_branch}..HEAD")
    
    if not code_changes:
        print("No diff found against public repo, trying IBM fork...")
        code_changes = run_git_command(f"git diff origin/{base_branch}..HEAD")
    
    # Get commit messages
    print("Getting commit messages...")
    commit_messages = run_git_command(
        f"git log public/{base_branch}..HEAD --pretty=format:'%s%n%b' || git log origin/{base_branch}..HEAD --pretty=format:'%s%n%b'"
    )
    
    # Get changed files
    print("Getting changed files...")
    changed_files = run_git_command(
        f"git diff --name-only public/{base_branch}..HEAD || git diff --name-only origin/{base_branch}..HEAD"
    )
    
    # Get author information
    author_name = run_git_command("git log -1 --pretty=format:'%an'")
    author_email = run_git_command("git log -1 --pretty=format:'%ae'")
    
    # Check for IBM-specific patterns that should be removed
    ibm_patterns_found = []
    
    # Check for IBM internal URLs
    if '.ibm.com' in code_changes or '.ibm.com' in commit_messages:
        ibm_patterns_found.append("IBM internal URLs detected")
    
    # Check for IBM project names (common ones)
    ibm_projects = ['watson', 'bluemix', 'softlayer', 'cloud-pak']
    for project in ibm_projects:
        if project.lower() in code_changes.lower() or project.lower() in commit_messages.lower():
            ibm_patterns_found.append(f"IBM project reference: {project}")
    
    # Compile PR content
    pr_content = {
        "pr_title": pr_title,
        "pr_body": pr_body,
        "code_changes": code_changes[:10000],  # Limit size
        "commit_messages": commit_messages,
        "changed_files": changed_files.split('\\n') if changed_files else [],
        "author": {
            "name": author_name,
            "email": author_email,
            "is_ibm": '@ibm.com' in author_email.lower()
        },
        "metadata": {
            "branch": os.getenv('GIT_BRANCH', 'unknown'),
            "base_branch": base_branch,
            "commit": os.getenv('GIT_COMMIT', 'unknown'),
            "pr_number": os.getenv('CHANGE_ID', 'N/A'),
            "ibm_fork": os.getenv('IBM_FORK_REPO', 'unknown'),
            "public_repo": os.getenv('PUBLIC_REPO', 'unknown')
        },
        "warnings": ibm_patterns_found
    }
    
    print(f"✅ Collected PR content:")
    print(f"   - Title: {pr_title}")
    print(f"   - Author: {author_name} <{author_email}>")
    print(f"   - IBM Contributor: {'Yes' if pr_content['author']['is_ibm'] else 'No'}")
    print(f"   - Code changes: {len(code_changes)} chars")
    print(f"   - Commit messages: {len(commit_messages)} chars")
    print(f"   - Changed files: {len(pr_content['changed_files'])}")
    if ibm_patterns_found:
        print(f"   - ⚠️  Warnings: {len(ibm_patterns_found)}")
        for warning in ibm_patterns_found:
            print(f"      - {warning}")
    
    return pr_content

if __name__ == "__main__":
    base_branch = sys.argv[1] if len(sys.argv) > 1 else "main"
    
    pr_content = collect_pr_content(base_branch)
    
    # Save to file
    output_file = "pr_content.json"
    with open(output_file, 'w') as f:
        json.dump(pr_content, f, indent=2)
    
    print(f"\\n💾 PR content saved to: {output_file}")
'''
                    
                    // Run the collection script
                    sh """
                        cd ${VALIDATION_DIR}
                        chmod +x collect_pr_content.py
                        python3 collect_pr_content.py "${BASE_BRANCH}"
                    """
                    
                    // Verify the file was created
                    def prContentExists = fileExists("${VALIDATION_DIR}/pr_content.json")
                    if (!prContentExists) {
                        error("❌ Failed to collect PR content")
                    }
                    
                    echo "✅ PR content collected successfully"
                }
            }
        }
        
        stage('Bob Validation') {
            when {
                expression { !params.SKIP_VALIDATION }
            }
            steps {
                script {
                    echo "🤖 Running Bob Shell validation for public repository submission..."
                    
                    // Create enhanced validation script for public repos
                    writeFile file: "${VALIDATION_DIR}/validate_with_bob.py", text: '''#!/usr/bin/env python3
import json
import subprocess
import sys
import os

def validate_with_bob(pr_content_file):
    """Validate PR content using Bob Shell for public repo submission"""
    
    # Read PR content
    with open(pr_content_file, 'r') as f:
        pr_content = json.load(f)
    
    # Enhanced validation prompt for public repos
    prompt = f"""You are validating content from an IBM contributor that will be submitted to a PUBLIC external repository.

This is CRITICAL because:
1. The content will be publicly visible
2. It represents IBM in the open source community
3. Any issues will damage IBM's reputation
4. The external repository owners have strict standards

Please validate the following PR content for:

CRITICAL CHECKS:
1. Offensive language or unprofessional comments
2. IBM confidential information (internal URLs, project codenames, credentials)
3. Security vulnerabilities (exposed secrets, API keys, passwords, tokens)
4. Compliance violations (export control, licensing issues)
5. IBM-specific references that should be generic
6. Internal IBM tools or processes mentioned
7. Unprofessional tone or language

PR Content to Validate:
- Title: {pr_content.get('pr_title', '')}
- Body: {pr_content.get('pr_body', '')}
- Author: {pr_content.get('author', {}).get('name', 'Unknown')} ({pr_content.get('author', {}).get('email', 'Unknown')})
- IBM Contributor: {pr_content.get('author', {}).get('is_ibm', False)}
- Target: {pr_content.get('metadata', {}).get('public_repo', 'Unknown')}
- Commit Messages: {pr_content.get('commit_messages', '')}
- Changed Files: {', '.join(pr_content.get('changed_files', [])[:10])}
- Code Changes (first 2000 chars): {pr_content.get('code_changes', '')[:2000]}

Existing Warnings:
{chr(10).join('- ' + w for w in pr_content.get('warnings', []))}

Please respond in JSON format with:
{{
  "approved": true/false,
  "confidence": "HIGH/MEDIUM/LOW",
  "issues": [
    {{
      "type": "issue_type",
      "severity": "CRITICAL/HIGH/MEDIUM/LOW",
      "location": "where the issue was found",
      "message": "description of the issue",
      "suggestion": "how to fix it",
      "public_impact": "why this matters for public repo"
    }}
  ],
  "recommendations": [
    "additional recommendations for public submission"
  ]
}}

Be EXTRA strict because this is going to a public repository."""
    
    print("🤖 Calling Bob Shell for public repo validation...")
    print(f"Prompt length: {len(prompt)} characters")
    
    try:
        # Get Bob Shell path from environment, fallback to 'bob' in PATH
        bob_path = os.getenv('BOB_SHELL_PATH', 'bob')
        print(f"Using Bob Shell at: {bob_path}")
        
        # Call Bob Shell with positional prompt
        result = subprocess.run(
            [
                bob_path,
                '--output-format', 'json',
                '--chat-mode', 'code',
                prompt
            ],
            capture_output=True,
            text=True,
            timeout=120
        )
        
        print(f"Bob Shell exit code: {result.returncode}")
        
        if result.returncode == 0:
            # Try to parse JSON response
            try:
                bob_response = json.loads(result.stdout)
                
                # Add metadata
                bob_response['validation_type'] = 'public_repo'
                bob_response['target_repo'] = pr_content.get('metadata', {}).get('public_repo', 'Unknown')
                
                return bob_response
            except json.JSONDecodeError:
                print("⚠️  Bob response is not valid JSON, parsing text...")
                import re
                json_match = re.search(r'\\{[\\s\\S]*\\}', result.stdout)
                if json_match:
                    try:
                        return json.loads(json_match.group())
                    except:
                        pass
                
                # Fallback
                approved = "approved" in result.stdout.lower() and "true" in result.stdout.lower()
                return {
                    "approved": approved,
                    "confidence": "LOW",
                    "raw_response": result.stdout,
                    "note": "Response parsed from text output"
                }
        else:
            print(f"❌ Bob Shell error: {result.stderr}")
            return {
                "approved": False,
                "confidence": "LOW",
                "error": result.stderr,
                "stdout": result.stdout
            }
    
    except subprocess.TimeoutExpired:
        print("❌ Bob Shell timeout")
        return {
            "approved": False,
            "confidence": "LOW",
            "error": "Timeout waiting for Bob response (120s)"
        }
    
    except FileNotFoundError:
        print("❌ Bob Shell not found")
        return {
            "approved": False,
            "confidence": "LOW",
            "error": "Bob Shell executable not found"
        }
    
    except Exception as e:
        print(f"❌ Unexpected error: {e}")
        return {
            "approved": False,
            "confidence": "LOW",
            "error": str(e)
        }

if __name__ == "__main__":
    pr_content_file = sys.argv[1] if len(sys.argv) > 1 else "pr_content.json"
    
    print(f"📄 Validating for public repository: {pr_content_file}")
    
    result = validate_with_bob(pr_content_file)
    
    # Save result
    with open("bob_validation_result.json", 'w') as f:
        json.dump(result, f, indent=2)
    
    print("\\n" + "="*60)
    print("BOB VALIDATION RESULT (PUBLIC REPO)")
    print("="*60)
    print(json.dumps(result, indent=2))
    print("="*60)
    
    # Exit with appropriate code
    sys.exit(0 if result.get("approved", False) else 1)
'''
                    
                    // Run Bob validation
                    def validationResult = sh(
                        script: """
                            cd ${VALIDATION_DIR}
                            chmod +x validate_with_bob.py
                            python3 validate_with_bob.py pr_content.json
                        """,
                        returnStatus: true
                    )
                    
                    // Read validation results using native Groovy JSON parsing
                    def resultsFile = "${VALIDATION_DIR}/bob_validation_result.json"
                    if (fileExists(resultsFile)) {
                        // Read file content and parse JSON manually
                        def jsonContent = readFile(resultsFile)
                        def jsonSlurper = new groovy.json.JsonSlurper()
                        def results = jsonSlurper.parseText(jsonContent)
                        
                        // Store results in environment
                        env.BOB_APPROVED = results.approved.toString()
                        env.BOB_CONFIDENCE = results.confidence ?: 'UNKNOWN'
                        env.BOB_VALIDATION_RESULT = resultsFile
                        
                        if (validationResult != 0 || !results.approved) {
                            currentBuild.result = 'FAILURE'
                            error("❌ Bob validation failed for public repository submission. See validation results for details.")
                        } else {
                            echo "✅ Bob validation passed! Content is safe for public repository."
                            echo "   Confidence: ${env.BOB_CONFIDENCE}"
                        }
                    } else {
                        error("❌ Validation result file not found")
                    }
                }
            }
        }
        
