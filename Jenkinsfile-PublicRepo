                'VALIDATION', 'CONFIDENCE', 'THRESHOLD', 'MINIMUM'
            }
            programming_terms.update(essential_terms)

            return programming_terms

        # Get common English words dynamically
        def get_common_words():
            """Get common English words from NLTK or fallback list"""
            common = set()

            # Try to use NLTK's word corpus if available
            try:
                import nltk
