        # Combine programming terms and common words
        programming_terms = get_programming_terms()
        common_words = get_common_words()
        all_excluded = programming_terms.union(common_words)

        return [k for k in set(keywords) if k not in all_excluded and len(k) > 3]

    def check_keyword_on_internet(keyword):
        """Check if keyword exists on public internet using Google search"""
        import urllib.request
        import urllib.parse
        
        try:
            # Use Google search - most reliable and comprehensive
            query = urllib.parse.quote(f'{keyword} programming')
            url = f'https://www.google.com/search?q={query}'
            
            req = urllib.request.Request(url, headers={
                'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.124 Safari/537.36'
            })
            
            with urllib.request.urlopen(req, timeout=3) as response:
                if response.status == 200:
                    content = response.read().decode('utf-8', errors='ignore')
                    
                    # Check if Google found results
                    # Google shows "did not match any documents" when no results
                    if 'did not match any documents' in content.lower():
                        print(f"    ✗ Not found on Google")
                        return False
                    
                    # Check for substantial content (indicates results found)
                    if len(content) > 10000:
                        print(f"    ✓ Found on Google")
                        return True
                    
                    print(f"    ? Unclear results from Google")
                    return True  # Benefit of doubt
                    
        except Exception as e:
            print(f"    ⚠️  Google search failed: {str(e)[:80]}")
            # If search fails, give benefit of doubt (assume public)
            return True
        
        return True

    # Extract keywords from code changes and commit messages
    all_text = code_changes + ' ' + commit_messages
    keywords = extract_keywords(all_text)

    if keywords:
        print(f"Found {len(keywords)} unique keywords to verify on internet...")
        # Limit to top 15 most frequent keywords to avoid too many requests
        keywords = list(set(keywords))[:15]
        print(f"  Verifying: {', '.join(keywords)}")

