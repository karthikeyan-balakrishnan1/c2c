// Jenkinsfile for Public Repository - Bob Validation Pipeline
// Special configuration for IBM contributors to external/public repositories

pipeline {
    agent any
    
    environment {
        // GitHub credentials for public repo
        GITHUB_TOKEN = credentials('github-token')
        
        // Bob Shell API Key (required for authentication)
        // Create this credential in Jenkins: Manage Jenkins → Credentials → Add Credentials
        // Kind: Secret text, ID: bob-api-key
        BOB_API_KEY = credentials('bob-api-key')
        
        // IBM Fork repository (where validation happens)
        IBM_FORK_REPO = "${params.IBM_FORK_REPO ?: 'karthikeyan-balakrishnan-ibm/c2c'}"
        
        // External/Public repository (final destination)
        PUBLIC_REPO = "${params.PUBLIC_REPO ?: 'IBM/c2c'}"
        
        // Bob Shell configuration
        // Bob is a Node.js script symlinked at /opt/homebrew/bin/bob
        BOB_SHELL_PATH = '/opt/homebrew/bin/bob'
        BOB_JS_PATH = '/opt/homebrew/lib/node_modules/bobshell/bundle/bob.js'
        
        // Node.js configuration (required by Bob Shell)
        NODE_PATH = '/opt/homebrew/bin/node'  // Full path to node executable
        NODE_HOME = '/opt/homebrew/bin'  // Directory containing node
        PATH = "/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/bin:/bin:${env.PATH}"
        
        // Working directories
        WORKSPACE_DIR = "${WORKSPACE}"
        VALIDATION_DIR = "${WORKSPACE}/bob-validation"
        
        // Git configuration - supports any branch
        // Priority: Parameter > PR branch > Git branch > Branch name > Default
        GIT_BRANCH = "${params.BRANCH_TO_BUILD ?: env.CHANGE_BRANCH ?: env.GIT_BRANCH ?: env.BRANCH_NAME ?: 'main'}"
        BASE_BRANCH = "${env.CHANGE_TARGET ?: params.BASE_BRANCH ?: 'main'}"
        
        // IBM specific settings
        IBM_CONTRIBUTOR_EMAIL = "${env.CHANGE_AUTHOR_EMAIL ?: 'karthikeyan.balakrishnan1@ibm.com'}"
    }
    
    parameters {
        // Branch Selection
        string(
            name: 'BRANCH_TO_BUILD',
            defaultValue: 'main',
            description: 'Branch to build and validate (e.g., main, feature/new-api, develop)'
        )
        string(
            name: 'BASE_BRANCH',
            defaultValue: 'main',
            description: 'Base branch to compare against (e.g., main, develop, master)'
        )
        
        // Repository Configuration
        string(
            name: 'IBM_FORK_REPO',
            defaultValue: 'karthikeyan-balakrishnan-ibm/c2c',
            description: 'IBM fork repository (format: org/repo)'
        )
        string(
            name: 'PUBLIC_REPO',
            defaultValue: 'IBM/c2c',
            description: 'Public/external repository (format: org/repo)'
        )
        
        // Validation Options
        choice(
            name: 'VALIDATION_LEVEL',
            choices: ['STRICT', 'STANDARD', 'RELAXED'],
            description: 'Validation strictness level: STRICT (public repo), STANDARD (normal), RELAXED (internal only)'
        )
        booleanParam(
            name: 'SKIP_VALIDATION',
            defaultValue: false,
            description: '⚠️ Skip Bob validation (emergency only - requires approval)'
        )
        booleanParam(
            name: 'CHECK_OFFENSIVE_CONTENT',
            defaultValue: true,
            description: 'Check for offensive language and inappropriate content'
        )
        booleanParam(
            name: 'CHECK_CONFIDENTIAL_INFO',
            defaultValue: true,
            description: 'Check for IBM confidential information and internal references'
        )
        booleanParam(
            name: 'CHECK_SECURITY_ISSUES',
            defaultValue: true,
            description: 'Check for security vulnerabilities and exposed secrets'
        )
        booleanParam(
            name: 'CHECK_IBM_PATTERNS',
            defaultValue: true,
            description: 'Check for IBM-specific patterns that should be generic'
        )
        
        // PR Creation Options
        booleanParam(
            name: 'AUTO_CREATE_PR',
            defaultValue: true,
            description: 'Automatically create PR to public repo after validation passes'
        )
        string(
            name: 'PR_TITLE',
            defaultValue: '',
            description: 'Custom PR title (leave empty to use commit message)'
        )
        text(
            name: 'PR_DESCRIPTION',
            defaultValue: '',
            description: 'Custom PR description (leave empty to use commit body)'
        )
        
        // Notification Options
        booleanParam(
            name: 'SEND_EMAIL_NOTIFICATION',
            defaultValue: true,
            description: 'Send email notification on validation failure'
        )
        string(
            name: 'NOTIFICATION_EMAIL',
            defaultValue: '',
            description: 'Additional email addresses for notifications (comma-separated)'
        )
        
        // Advanced Options
        booleanParam(
            name: 'DEBUG_MODE',
            defaultValue: false,
            description: 'Enable verbose debug output'
        )
        booleanParam(
            name: 'DRY_RUN',
            defaultValue: false,
            description: 'Dry run mode - validate but don\'t create PR or update status'
        )
        choice(
            name: 'BOB_CONFIDENCE_THRESHOLD',
            choices: ['HIGH', 'MEDIUM', 'LOW'],
            description: 'Minimum confidence level required to pass validation'
        )
    }
    
    triggers {
        // Trigger on any branch push or PR
        githubPush()
    }
    
    options {
        buildDiscarder(logRotator(daysToKeepStr: '30', numToKeepStr: '50'))
        timeout(time: 20, unit: 'MINUTES')
        disableConcurrentBuilds()
        timestamps()
    }
    
    stages {
        stage('Initialize') {
            steps {
                script {
                    echo "🚀 Starting Bob Validation Pipeline for Public Repository"
                    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
                    echo "📋 Build Information:"
                    echo "   Job: ${env.JOB_NAME}"
                    echo "   Build: #${env.BUILD_NUMBER}"
                    echo "   IBM Fork: ${IBM_FORK_REPO}"
                    echo "   Public Repo: ${PUBLIC_REPO}"
                    echo "   Branch: ${GIT_BRANCH}"
                    echo "   Base Branch: ${BASE_BRANCH}"
                    echo "   PR: ${env.CHANGE_ID ?: 'N/A'}"
                    echo "   IBM Contributor: ${env.CHANGE_AUTHOR ?: 'N/A'}"
                    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
                    
                    // Verify this is an IBM contributor
                    if (IBM_CONTRIBUTOR_EMAIL && !IBM_CONTRIBUTOR_EMAIL.contains('@ibm.com')) {
                        echo "⚠️  Warning: Contributor email is not @ibm.com"
                        echo "   This pipeline is designed for IBM contributors only"
                    }
                    
                    // Create validation directory
                    sh """
                        mkdir -p ${VALIDATION_DIR}
                        echo "✅ Validation directory created: ${VALIDATION_DIR}"
                    """
                }
            }
        }
        
        stage('Verify Bob Shell') {
            steps {
                script {
                    echo "🔍 Verifying Bob Shell and Node.js availability..."
                    echo "   Bob Shell Path: ${BOB_SHELL_PATH}"
                    echo "   Node.js Path: ${NODE_HOME}"
                    echo "   Current PATH: ${env.PATH}"
                    
                    def verificationCheck = sh(
                        script: """
                            set +e  # Don't exit on error
                            ERRORS=0
                            
                            # Check Node.js
                            echo ""
                            echo "=== Checking Node.js ==="
                            if command -v node >/dev/null 2>&1; then
                                NODE_VERSION=\$(node --version)
                                echo "✅ Node.js found: \$NODE_VERSION"
                                echo "   Location: \$(which node)"
                            else
                                echo "❌ Node.js not found in PATH"
                                echo ""
                                echo "Searching for Node.js in common locations..."
                                ls -la /usr/bin/node 2>/dev/null || echo "  - Not in /usr/bin"
                                ls -la /usr/local/bin/node 2>/dev/null || echo "  - Not in /usr/local/bin"
                                ls -la /opt/homebrew/bin/node 2>/dev/null || echo "  - Not in /opt/homebrew/bin"
                                ls -la ~/.nvm/versions/node/*/bin/node 2>/dev/null || echo "  - Not in ~/.nvm"
                                echo ""
                                echo "⚠️  Bob Shell requires Node.js to run!"
                                echo "Please install Node.js or update NODE_HOME in Jenkinsfile"
                                ERRORS=\$((ERRORS + 1))
                            fi
                            
                            # Check Bob Shell
                            echo ""
                            echo "=== Checking Bob Shell ==="
                            if [ -f "${BOB_SHELL_PATH}" ]; then
                                echo "✅ Bob Shell found at: ${BOB_SHELL_PATH}"
                                
                                # Try to run Bob
                                if ${BOB_SHELL_PATH} --help >/dev/null 2>&1; then
                                    echo "✅ Bob Shell is executable and working"
                                    ${BOB_SHELL_PATH} --help | head -5
                                else
                                    echo "⚠️  Bob Shell exists but failed to run"
                                    echo "This might be due to missing Node.js or permissions"
                                    ERRORS=\$((ERRORS + 1))
                                fi
                            else
                                echo "❌ Bob Shell not found at: ${BOB_SHELL_PATH}"
                                echo ""
                                echo "Searching for Bob in common locations..."
                                which bob || echo "  - Not in PATH"
                                ls -la /usr/local/bin/bob 2>/dev/null || echo "  - Not in /usr/local/bin"
                                ls -la /opt/homebrew/bin/bob 2>/dev/null || echo "  - Not in /opt/homebrew/bin"
                                ls -la /opt/ibm/bob/bin/bob 2>/dev/null || echo "  - Not in /opt/ibm"
                                ls -la ~/.local/bin/bob 2>/dev/null || echo "  - Not in ~/.local/bin"
                                echo ""
                                echo "Please update BOB_SHELL_PATH in Jenkinsfile environment section"
                                ERRORS=\$((ERRORS + 1))
                            fi
                            
                            echo ""
                            echo "=== Verification Summary ==="
                            if [ \$ERRORS -eq 0 ]; then
                                echo "✅ All checks passed!"
                                exit 0
                            else
                                echo "❌ \$ERRORS error(s) found"
                                echo ""
                                echo "Common fixes:"
                                echo "1. Install Node.js: https://nodejs.org/"
                                echo "2. Update NODE_HOME in Jenkinsfile to point to Node.js bin directory"
                                echo "3. Update BOB_SHELL_PATH to correct Bob location"
                                echo "4. Ensure PATH includes both Node.js and Bob directories"
                                exit 1
                            fi
                        """,
                        returnStatus: true
                    )
                    
                    if (verificationCheck != 0) {
                        error("❌ Verification failed. Please check Node.js and Bob Shell installation.")
                    }
                    
                    echo "✅ Node.js and Bob Shell verified successfully"
                }
            }
        }
        
        stage('Checkout IBM Fork') {
            steps {
                script {
                    echo "📥 Checking out IBM fork repository..."
                    
                    // Checkout from IBM fork (not public repo)
                    checkout([
                        $class: 'GitSCM',
                        branches: [[name: "*/${GIT_BRANCH}"]],
                        userRemoteConfigs: [[
                            url: "https://github.com/${IBM_FORK_REPO}.git",
                            credentialsId: 'github-token'
                        ]]
                    ])
                    
                    // Add public repo as remote for reference
                    sh """
                        git remote add public https://github.com/${PUBLIC_REPO}.git || true
                        git fetch --all --prune
                        git branch -a
                        echo "✅ IBM fork checked out successfully"
                    """
                }
            }
        }
        
        stage('Verify IBM Fork Sync') {
            steps {
                script {
                    echo "🔄 Verifying IBM fork is synced with public repo..."
                    
                    sh """
                        # Fetch latest from public repo
                        git fetch public ${BASE_BRANCH}
                        
                        # Check if fork is behind
                        BEHIND=\$(git rev-list --count HEAD..public/${BASE_BRANCH})
                        
                        if [ "\$BEHIND" -gt 0 ]; then
                            echo "⚠️  IBM fork is \$BEHIND commits behind public repo"
                            echo "   Consider syncing the fork before proceeding"
                        else
                            echo "✅ IBM fork is up to date with public repo"
                        fi
                    """
                }
            }
        }
        
        stage('Collect PR Content') {
            steps {
                script {
                    echo "📦 Collecting PR content for validation..."
                    
                    // Create enhanced collection script for public repos
                    writeFile file: "${VALIDATION_DIR}/collect_pr_content.py", text: '''#!/usr/bin/env python3
import json
import subprocess
import sys
import os
import time

def run_git_command(cmd):
    """Run git command and return output"""
    try:
        result = subprocess.run(
            cmd,
            capture_output=True,
            text=True,
            check=True,
            shell=True
        )
        return result.stdout.strip()
    except subprocess.CalledProcessError as e:
        print(f"Error running command: {cmd}")
        print(f"Error: {e.stderr}")
        return ""

def collect_pr_content(base_branch):
    """Collect all PR content for public repo submission"""
    print(f"Collecting PR content (base: {base_branch})...")
    
    # Get PR title from commit or environment
    pr_title = os.getenv('CHANGE_TITLE', run_git_command("git log -1 --pretty=format:'%s'"))
    
    # Get PR body/description
    pr_body = os.getenv('CHANGE_DESCRIPTION', run_git_command("git log -1 --pretty=format:'%b'"))
    
    # Get code changes (diff against public repo)
    print("Getting code diff against public repo...")
    code_changes = run_git_command(f"git diff public/{base_branch}..HEAD")
    
    if not code_changes:
        print("No diff found against public repo, trying IBM fork...")
        code_changes = run_git_command(f"git diff origin/{base_branch}..HEAD")
    
    # Get commit messages
    print("Getting commit messages...")
    commit_messages = run_git_command(
        f"git log public/{base_branch}..HEAD --pretty=format:'%s%n%b' || git log origin/{base_branch}..HEAD --pretty=format:'%s%n%b'"
    )
    
    # Get changed files
    print("Getting changed files...")
    changed_files = run_git_command(
        f"git diff --name-only public/{base_branch}..HEAD || git diff --name-only origin/{base_branch}..HEAD"
    )
    
    # Get author information
    author_name = run_git_command("git log -1 --pretty=format:'%an'")
    author_email = run_git_command("git log -1 --pretty=format:'%ae'")
    
    # Check for IBM-specific patterns and internal keywords
    ibm_patterns_found = []
    internal_keywords_found = []
    
    # Check for IBM internal URLs
    if '.ibm.com' in code_changes or '.ibm.com' in commit_messages:
        ibm_patterns_found.append("IBM internal URLs detected")
    
    # Check for IBM project names (common ones)
    ibm_projects = ['watson', 'bluemix', 'softlayer', 'cloud-pak', 'websphere', 'db2', 'cognos', 'maximo']
    for project in ibm_projects:
        if project.lower() in code_changes.lower() or project.lower() in commit_messages.lower():
            ibm_patterns_found.append(f"IBM project reference: {project}")
    
    # Extract and verify keywords against internet
    print("Extracting keywords for internet verification...")
    
    def extract_keywords(text):
        """Extract potential keywords/identifiers from text"""
        import re
        # Extract camelCase, snake_case, and UPPER_CASE identifiers
        # Exclude common words and focus on technical terms
        pattern = r'\\b[A-Z][a-z]+(?:[A-Z][a-z]+)+\\b|\\b[a-z]+_[a-z_]+\\b|\\b[A-Z]{2,}(?:_[A-Z]+)*\\b'
        keywords = re.findall(pattern, text)
        # Filter out very common words
        common_words = {'GET', 'POST', 'PUT', 'DELETE', 'HTTP', 'HTTPS', 'API', 'URL', 'JSON', 'XML'}
        return [k for k in set(keywords) if k not in common_words and len(k) > 3]
    
    def check_keyword_on_internet(keyword):
        """Check if keyword exists on public internet using multiple methods"""
        import urllib.request
        import urllib.parse
        import time
        
        try:
            # Method 1: Check via DuckDuckGo (no API key needed)
            query = urllib.parse.quote(f'"{keyword}" programming')
            url = f'https://html.duckduckgo.com/html/?q={query}'
            
            req = urllib.request.Request(url, headers={
                'User-Agent': 'Mozilla/5.0 (compatible; ValidationBot/1.0)'
            })
            
            with urllib.request.urlopen(req, timeout=5) as response:
                content = response.read().decode('utf-8', errors='ignore')
                # If we get substantial results, keyword is likely public
                if 'No results' in content or len(content) < 1000:
                    return False
                return True
                
        except Exception as e:
            print(f"  Warning: Could not verify '{keyword}': {e}")
            # If we can't verify, assume it might be internal (safer)
            return False
    
    # Extract keywords from code changes and commit messages
    all_text = code_changes + ' ' + commit_messages
    keywords = extract_keywords(all_text)
    
    if keywords:
        print(f"Found {len(keywords)} unique keywords to verify...")
        # Limit to top 20 most frequent keywords to avoid too many requests
        keywords = list(set(keywords))[:20]
        
        for keyword in keywords:
            print(f"  Checking: {keyword}")
            if not check_keyword_on_internet(keyword):
                internal_keywords_found.append({
                    "keyword": keyword,
                    "reason": "Not found in public internet search - possibly internal/proprietary term"
                })
                print(f"    ⚠️  Potentially internal: {keyword}")
            else:
                print(f"    ✓ Public term: {keyword}")
            
            # Rate limiting to be respectful
            time.sleep(0.5)
    
    if internal_keywords_found:
        ibm_patterns_found.append(f"Potentially internal keywords detected: {len(internal_keywords_found)} terms")
    
    # Compile PR content
    pr_content = {
        "pr_title": pr_title,
        "pr_body": pr_body,
        "code_changes": code_changes[:10000],  # Limit size
        "commit_messages": commit_messages,
        "changed_files": changed_files.split('\\n') if changed_files else [],
        "author": {
            "name": author_name,
            "email": author_email,
            "is_ibm": '@ibm.com' in author_email.lower()
        },
        "metadata": {
            "branch": os.getenv('GIT_BRANCH', 'unknown'),
            "base_branch": base_branch,
            "commit": os.getenv('GIT_COMMIT', 'unknown'),
            "pr_number": os.getenv('CHANGE_ID', 'N/A'),
            "ibm_fork": os.getenv('IBM_FORK_REPO', 'unknown'),
            "public_repo": os.getenv('PUBLIC_REPO', 'unknown')
        },
        "warnings": ibm_patterns_found,
        "internal_keywords": internal_keywords_found  # Add internal keywords for detailed reporting
    }
    
    print(f"✅ Collected PR content:")
    print(f"   - Title: {pr_title}")
    print(f"   - Author: {author_name} <{author_email}>")
    print(f"   - IBM Contributor: {'Yes' if pr_content['author']['is_ibm'] else 'No'}")
    print(f"   - Code changes: {len(code_changes)} chars")
    print(f"   - Commit messages: {len(commit_messages)} chars")
    print(f"   - Changed files: {len(pr_content['changed_files'])}")
    if ibm_patterns_found:
        print(f"   - ⚠️  Warnings: {len(ibm_patterns_found)}")
        for warning in ibm_patterns_found:
            print(f"      - {warning}")
    if internal_keywords_found:
        print(f"   - 🔍 Internal Keywords Found: {len(internal_keywords_found)}")
        for kw in internal_keywords_found[:5]:  # Show first 5
            print(f"      - {kw['keyword']}: {kw['reason']}")
        if len(internal_keywords_found) > 5:
            print(f"      - ... and {len(internal_keywords_found) - 5} more")
    
    return pr_content

if __name__ == "__main__":
    base_branch = sys.argv[1] if len(sys.argv) > 1 else "main"
    
    pr_content = collect_pr_content(base_branch)
    
    # Save to file
    output_file = "pr_content.json"
    with open(output_file, 'w') as f:
        json.dump(pr_content, f, indent=2)
    
    print(f"\\n💾 PR content saved to: {output_file}")
'''
                    
                    // Run the collection script
                    sh """
                        cd ${VALIDATION_DIR}
                        chmod +x collect_pr_content.py
                        python3 collect_pr_content.py "${BASE_BRANCH}"
                    """
                    
                    // Verify the file was created
                    def prContentExists = fileExists("${VALIDATION_DIR}/pr_content.json")
                    if (!prContentExists) {
                        error("❌ Failed to collect PR content")
                    }
                    
                    echo "✅ PR content collected successfully"
                }
            }
        }
        
        stage('Bob Validation') {
            when {
                expression { !params.SKIP_VALIDATION }
            }
            steps {
                script {
                    echo "🤖 Running Bob Shell validation for public repository submission..."
                    
                    // Create enhanced validation script for public repos
                    writeFile file: "${VALIDATION_DIR}/validate_with_bob.py", text: '''#!/usr/bin/env python3
import json
import subprocess
import sys
import os

def validate_with_bob(pr_content_file):
    """Validate PR content using Bob Shell for public repo submission"""
    
    # Read PR content
    with open(pr_content_file, 'r') as f:
        pr_content = json.load(f)
    
    # Enhanced validation prompt for public repos
    prompt = f"""You are validating content from an IBM contributor that will be submitted to a PUBLIC external repository.

This is CRITICAL because:
1. The content will be publicly visible
2. It represents IBM in the open source community
3. Any issues will damage IBM's reputation
4. The external repository owners have strict standards

Please validate the following PR content for:

CRITICAL CHECKS:
1. Offensive language or unprofessional comments
2. IBM confidential information (internal URLs, project codenames, credentials)
3. Security vulnerabilities (exposed secrets, API keys, passwords, tokens)
4. Compliance violations (export control, licensing issues)
5. IBM-specific references that should be generic
6. Internal IBM tools or processes mentioned
7. Unprofessional tone or language
8. Internal/proprietary keywords not found in public internet searches

PR Content to Validate:
- Title: {pr_content.get('pr_title', '')}
- Body: {pr_content.get('pr_body', '')}
- Author: {pr_content.get('author', {}).get('name', 'Unknown')} ({pr_content.get('author', {}).get('email', 'Unknown')})
- IBM Contributor: {pr_content.get('author', {}).get('is_ibm', False)}
- Target: {pr_content.get('metadata', {}).get('public_repo', 'Unknown')}
- Commit Messages: {pr_content.get('commit_messages', '')}
- Changed Files: {', '.join(pr_content.get('changed_files', [])[:10])}
- Code Changes (first 2000 chars): {pr_content.get('code_changes', '')[:2000]}

Existing Warnings:
{chr(10).join('- ' + w for w in pr_content.get('warnings', []))}

Internal Keywords Detected (not found in public internet):
{chr(10).join('- ' + kw['keyword'] + ': ' + kw['reason'] for kw in pr_content.get('internal_keywords', [])[:10])}
{('... and ' + str(len(pr_content.get('internal_keywords', [])) - 10) + ' more internal keywords') if len(pr_content.get('internal_keywords', [])) > 10 else ''}

Please respond in JSON format with:
{{
  "approved": true/false,
  "confidence": "HIGH/MEDIUM/LOW",
  "issues": [
    {{
      "type": "issue_type",
      "severity": "CRITICAL/HIGH/MEDIUM/LOW",
      "location": "where the issue was found",
      "message": "description of the issue",
      "suggestion": "how to fix it",
      "public_impact": "why this matters for public repo"
    }}
  ],
  "recommendations": [
    "additional recommendations for public submission"
  ]
}}

Be EXTRA strict because this is going to a public repository."""
    
    print("🤖 Calling Bob Shell for public repo validation...")
    print(f"Prompt length: {len(prompt)} characters")
    
    try:
        # Get Bob Shell and Node.js paths from environment
        bob_path = os.getenv('BOB_SHELL_PATH', 'bob')
        node_path = os.getenv('NODE_PATH', 'node')
        bob_js_path = os.getenv('BOB_JS_PATH', '')
        bob_api_key = os.getenv('BOB_API_KEY', '')
        
        if not bob_api_key:
            print("❌ ERROR: BOB_API_KEY environment variable is not set!")
            return {
                "approved": False,
                "confidence": "LOW",
                "error": "Bob Shell API key not configured in Jenkins"
            }
        
        # Prepare environment with API key
        bob_env = {
            **os.environ,
            'PATH': f"/opt/homebrew/bin:{os.environ.get('PATH', '')}",
            'API_KEY': bob_api_key,
            'BOBSHELL_API_KEY': bob_api_key,
            'BOB_API_KEY': bob_api_key
        }
        
        # Bob is a Node.js script, so we can call it directly or via node
        # Try direct execution first (if bob is executable and in PATH)
        # If that fails, try running via node explicitly
        
        # Method 1: Try direct execution (works if bob is in PATH and executable)
        try:
            result = subprocess.run(
                [
                    bob_path,
                    '--output-format', 'json',
                    '--chat-mode', 'code',
                    prompt
                ],
                capture_output=True,
                text=True,
                timeout=120,
                env=bob_env
            )
            
            if result.returncode != 0 and 'node' in result.stderr.lower():
                # If it failed due to node not found, try Method 2
                raise FileNotFoundError("Node.js not found, trying explicit node execution")
                
        except (FileNotFoundError, PermissionError) as e:
            # Method 2: Execute Bob.js directly with Node.js
            print(f"Direct execution failed ({e}), trying with explicit node...")
            if bob_js_path and os.path.exists(bob_js_path):
                result = subprocess.run(
                    [
                        node_path,
                        bob_js_path,
                        '--output-format', 'json',
                        '--chat-mode', 'code',
                        prompt
                    ],
                    capture_output=True,
                    text=True,
                    timeout=120,
                    env=bob_env
                )
            else:
                # Fallback: try with just 'bob' in PATH
                result = subprocess.run(
                    [
                        'bob',
                        '--output-format', 'json',
                        '--chat-mode', 'code',
                        prompt
                    ],
                    capture_output=True,
                    text=True,
                    timeout=120,
                    env=bob_env
                )
        
        if result.returncode == 0:
            # Parse Bob Shell response
            output = result.stdout
            
            # Extract JSON from output markers
            if '---output---' in output:
                json_start = output.find('---output---') + len('---output---')
                json_str = output[json_start:].strip()
            else:
                json_str = output.strip()
            
            # Try to parse JSON - handle extra data after JSON
            import re
            try:
                # First, try to extract just the JSON object
                json_match = re.search(r'\\{(?:[^{}]|\\{[^{}]*\\})*\\}', json_str, re.DOTALL)
                if json_match:
                    json_str = json_match.group()
                
                # Parse JSON
                bob_response = json.loads(json_str)
                
                # Add metadata
                bob_response['validation_type'] = 'public_repo'
                bob_response['target_repo'] = pr_content.get('metadata', {}).get('public_repo', 'Unknown')
                
                return bob_response
                
            except (json.JSONDecodeError, AttributeError) as e:
                # Silently try alternative parsing methods
                # Try to find JSON in the output using more aggressive regex
                json_patterns = [
                    r'\\{[\\s\\S]*?\\}(?=\\s*$)',  # JSON at end
                    r'\\{[\\s\\S]*?\\}(?=\\s*---)',  # JSON before markers
                    r'\\{[\\s\\S]*?\\}'  # Any JSON
                ]
                
                for pattern in json_patterns:
                    try:
                        match = re.search(pattern, output)
                        if match:
                            bob_response = json.loads(match.group())
                            bob_response['validation_type'] = 'public_repo'
                            bob_response['target_repo'] = pr_content.get('metadata', {}).get('public_repo', 'Unknown')
                            return bob_response
                    except:
                        continue
                
                # If all parsing fails, return error
                return {
                    "approved": False,
                    "confidence": "LOW",
                    "error": "Failed to parse Bob Shell response",
                    "raw_output": result.stdout[:500]  # First 500 chars only
                }
        else:
            # Bob Shell failed - capture detailed error info
            error_details = {
                "approved": False,
                "confidence": "LOW",
                "error": f"Bob Shell exited with code {result.returncode}",
                "stderr": result.stderr[:1000] if result.stderr else "No error output",
                "stdout": result.stdout[:1000] if result.stdout else "No stdout"
            }
            
            # Print detailed error for debugging
            print(f"❌ Bob Shell Error Details:")
            print(f"   Return Code: {result.returncode}")
            print(f"   STDERR: {result.stderr[:500] if result.stderr else 'None'}")
            print(f"   STDOUT: {result.stdout[:500] if result.stdout else 'None'}")
            
            return error_details
    
    except subprocess.TimeoutExpired:
        print("❌ Bob Shell timeout")
        return {
            "approved": False,
            "confidence": "LOW",
            "error": "Timeout waiting for Bob response (120s)"
        }
    
    except FileNotFoundError:
        print("❌ Bob Shell not found")
        return {
            "approved": False,
            "confidence": "LOW",
            "error": "Bob Shell executable not found"
        }
    
    except Exception as e:
        print(f"❌ Unexpected error: {e}")
        return {
            "approved": False,
            "confidence": "LOW",
            "error": str(e)
        }

def format_validation_result(result, pr_content=None):
    """Format validation result for human-readable output"""
    output = []
    output.append("\\n" + "="*70)
    output.append("🤖 BOB VALIDATION RESULT - PUBLIC REPOSITORY SUBMISSION")
    output.append("="*70)
    
    # Status
    approved = result.get("approved", False)
    confidence = result.get("confidence", "UNKNOWN")
    status_icon = "✅" if approved else "❌"
    
    output.append(f"\\n{status_icon} STATUS: {'APPROVED' if approved else 'REJECTED'}")
    output.append(f"📊 CONFIDENCE: {confidence}")
    output.append(f"🎯 TARGET: {result.get('target_repo', 'Unknown')}")
    
    # Internal Keywords Warning (if available from pr_content)
    if pr_content:
        internal_keywords = pr_content.get("internal_keywords", [])
        if internal_keywords:
            output.append(f"\\n🔍 INTERNAL KEYWORDS DETECTED: {len(internal_keywords)}")
            output.append("-" * 70)
            output.append("   The following keywords were not found in public internet searches,")
            output.append("   suggesting they may be internal/proprietary terms:")
            for kw in internal_keywords[:10]:  # Show first 10
                output.append(f"   • {kw['keyword']}")
            if len(internal_keywords) > 10:
                output.append(f"   ... and {len(internal_keywords) - 10} more")
            output.append("   ⚠️  Review these terms to ensure they are appropriate for public repos")
    
    # Issues
    issues = result.get("issues", [])
    if issues:
        output.append(f"\\n⚠️  ISSUES FOUND: {len(issues)}")
        output.append("-" * 70)
        for i, issue in enumerate(issues, 1):
            output.append(f"\\n{i}. {issue.get('type', 'Unknown').upper().replace('_', ' ')}")
            output.append(f"   Severity: {issue.get('severity', 'UNKNOWN')}")
            output.append(f"   Location: {issue.get('location', 'Not specified')}")
            output.append(f"   Message: {issue.get('message', 'No message')}")
            if issue.get('suggestion'):
                output.append(f"   💡 Suggestion: {issue.get('suggestion')}")
            if issue.get('public_impact'):
                output.append(f"   🌐 Public Impact: {issue.get('public_impact')}")
    else:
        output.append("\\n✅ NO ISSUES FOUND")
    
    # Recommendations
    recommendations = result.get("recommendations", [])
    if recommendations:
        output.append(f"\\n💡 RECOMMENDATIONS:")
        output.append("-" * 70)
        for i, rec in enumerate(recommendations, 1):
            output.append(f"{i}. {rec}")
    
    # Error handling
    if result.get("error"):
        output.append(f"\\n❌ ERROR: {result.get('error')}")
    
    output.append("\\n" + "="*70)
    
    return "\\n".join(output)

